# Edge Functions — copy to `.env` in this directory.
# Git ignores `supabase/functions/.env`. Restart the stack after editing:
#   npm run supabase:stop && npm run supabase:start
#
# Get a key: https://aistudio.google.com/apikey

GEMINI_API_KEY=

# send-transactional-email (Resend welcome mail) — set in Supabase Dashboard secrets for production
# RESEND_API_KEY=re_xxx
# WEBHOOK_SECRET=long-random-string-matching-database-webhook-header
# FROM_EMAIL=no-reply@gymlogic.me
# APP_NAME=GymLogic
# SKIP_EMAIL_DOMAINS=example.com
# Optional: separate secret for unsubscribe links (defaults to WEBHOOK_SECRET)
# UNSUBSCRIBE_SECRET=
